BROWSER=firefox
APP_ENV=development
APP_NAME=MidoriVPN

PORT=3000
HOST=localhost

# When true, the built manifest declares all-site access as a required host permission.
# Set to false only for builds that should request this host permission at runtime.
REQUIRE_ALL_URLS_PERMISSION=true

# Seconds to show the granted countdown before closing welcome.html.
PERMISSIONS_CLOSE_DELAY_SECONDS=3

# vpn-core backend URL (Control API + Auth)
API_URL=https://vpn.astian.org

# URL opened when the user clicks "Manage Account"
ACCOUNT_URL=https://vpn.astian.org

# Authentik OIDC provider
AUTHENTIK_ISSUER=https://accounts.astian.org/application/o/midori-vpn
AUTHENTIK_CLIENT_ID=
# Authentik authorization endpoint (from your Authentik OIDC discovery)
AUTHENTIK_AUTHORIZATION_URL=https://accounts.astian.org/application/o/authorize/
AUTHENTIK_REDIRECT_URI=https://vpn.astian.org/extension/callback
