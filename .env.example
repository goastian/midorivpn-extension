BROWSER=firefox
APP_ENV=development
APP_NAME=MidoriVPN

PORT=3000
HOST=localhost

# vpn-core backend URL (Control API + Auth)
API_URL=https://vpn.astian.org

# Authentik OIDC provider
AUTHENTIK_ISSUER=https://accounts.astian.org/application/o/midori-vpn
AUTHENTIK_CLIENT_ID=
# Authentik authorization endpoint (from your Authentik OIDC discovery)
AUTHENTIK_AUTHORIZATION_URL=https://accounts.astian.org/application/o/authorize/
AUTHENTIK_REDIRECT_URI=https://vpn.astian.org/auth/callback