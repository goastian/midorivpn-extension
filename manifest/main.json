{
  "manifest_version": 3,
  "name": "MidoriVPN",
  "description": "Surf the web safely and privately with Midori VPN",
  "version": "2.0.0",
  "author": "Astian, Inc.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "alarms",
    "storage",
    "proxy",
    "tabs",
    "webRequest",
    "webNavigation"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}